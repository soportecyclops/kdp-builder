[Unit]
Description=KDP Builder WebUI
After=network-online.target
Wants=network-online.target

[Service]
User=administrador
WorkingDirectory=/home/administrador/kdp
ExecStart=/home/administrador/kdp/venv/bin/python -m uvicorn webui:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
